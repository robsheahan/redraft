ANTHROPIC_API_KEY=your-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# Provider routing. Leave as Anthropic to preserve current production behaviour.
# Each tier can be switched independently during the pilot.
AI_PRIMARY_PROVIDER=anthropic
AI_FAST_PROVIDER=anthropic
AI_FALLBACK_PROVIDER=anthropic
OPENAI_PRIMARY_MODEL=gpt-5.6-terra
OPENAI_FAST_MODEL=gpt-5.4-nano
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
