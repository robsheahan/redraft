{
  "outputDirectory": "public",
  "functions": {
    "api/generate-feedback.ts": { "maxDuration": 300 },
    "api/generate-class-feedback.ts": { "maxDuration": 300 },
    "api/generate-maths-feedback.ts": { "maxDuration": 300 },
    "api/generate-multi-feedback.ts": { "maxDuration": 300 },
    "api/generate-activity.ts": { "maxDuration": 300 },
    "api/generate-criteria.ts": { "maxDuration": 300 },
    "api/generate-marking-guideline.ts": { "maxDuration": 300 },
    "api/insights-card-generate.ts": { "maxDuration": 300 },
    "api/insights-synthesis.ts": { "maxDuration": 300 },
    "api/structure-maths-working.ts": { "maxDuration": 300 },
    "api/transcribe-maths-working.ts": { "maxDuration": 300 },
    "api/transcribe-maths-authoring.ts": { "maxDuration": 300 },
    "api/student-profile.ts": { "maxDuration": 300 },
    "api/submit-for-marking.ts": { "maxDuration": 300 },
    "api/task.ts": { "maxDuration": 300 },
    "api/lti/launch.ts": { "maxDuration": 300 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors 'self' https://*.instructure.com" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/lti/:path*", "destination": "/api/lti/:path*" },
    { "source": "/health", "destination": "/api/health" },
    { "source": "/deck", "destination": "/deck.html" },
    { "source": "/handout", "destination": "/handout.pdf" }
  ]
}
